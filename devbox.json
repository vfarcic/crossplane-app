{
  "packages": [
    "kind@0.30.0",
    "gh@2.83.2",
    "kubectl@1.34.3",
    "yq-go@4.50.1",
    "go-task@3.45.5",
    "kubernetes-helm@3.19.1",
    "kyverno-chainsaw@0.2.14",
    "kcl-cli@0.8.9",
    "vals@0.42.6",
    "git@2.51.2",
    "kubectl-tree@0.4.6",
    "nushell@0.108.0",
    "upbound@0.40.3",
    "azure-cli@2.81.0",
    "crossplane-cli@2.1.3",
    "upcloud-cli@3.29.0",
    "jq@1.8.1",
    "hey@0.1.4"
  ],
  "shell": {
    "init_hook": [
      "export PATH=$PATH:$HOME/.npm-global/bin",
      "[ -n \"$USE_VALS\" ] && eval \"$(vals env -export -f .env.vals.yaml)\" || true",
      "[ -f .env ] && source .env || true"
    ],
    "scripts": {
      "cluster-create":  ["./dot.nu setup"],
      "cluster-destroy": ["./dot.nu destroy"],
      "package-publish": ["task package-publish"],
      "test":            ["./dot.nu setup", "task test-once"],
      "test-watch":      ["task test-watch"]
    }
  }
}
